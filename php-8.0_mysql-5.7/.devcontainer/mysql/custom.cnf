[mysqld]
# SQL Mode - exclusion of problematic modes
# Excluded: ONLY_FULL_GROUP_BY, STRICT_TRANS_TABLES, STRICT_ALL_TABLES
sql_mode=NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION

# Character set
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

# Performance
innodb_buffer_pool_size=256M
innodb_log_file_size=64M

# Increase max_allowed_packet to 256MB (default is 4MB in MySQL 5.7)
# This is required for large INSERT queries during batch product imports
max_allowed_packet=256M

# Increase timeouts to 1 hour (default is 28800s = 8h for wait_timeout)
# This ensures that long imports will not be interrupted due to connection timeout
wait_timeout=3600
interactive_timeout=3600

# Increase net_read_timeout and net_write_timeout (default is 30s)
# This ensures that large data can be transferred without timeout
net_read_timeout=300
net_write_timeout=300

# Increase connect_timeout (default is 10s)
connect_timeout=60
