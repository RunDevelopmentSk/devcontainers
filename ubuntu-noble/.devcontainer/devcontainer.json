{
  "name": "${localWorkspaceFolderBasename}",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/home/ubuntu/workspaces/${localWorkspaceFolderBasename}",
  "postStartCommand": "bash ./.devcontainer/post-start.sh",
  "postCreateCommand": "bash ./.devcontainer/post-create.sh",
  "containerEnv": {
    "DOCKER_WORKDIR_LOCAL_BASENAME": "${localWorkspaceFolderBasename}"
  },
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "debugpy"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // The "ms-python.python" extension installs automatically
        // "ms-python.debugpy" and "ms-python.vscode-pylance" too
        "ms-python.python",
        "ms-python.pylint",
        "charliermarsh.ruff",
        "njpwerner.autodocstring",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "mhutchie.git-graph",
        "DotJoshJohnson.xml",
        "mechatroner.rainbow-csv",
        "geddski.macros",
        "openai.chatgpt",
        "anthropic.claude-code"
      ],
      "settings": {
        // general settings
        "window.title": "${dirty}${rootName}${separator}${activeEditorShort}${separator}${profileName}${separator}${appName}",
        "workbench.editor.openPositioning": "last",
        "editor.renderWhitespace": "all",
        "editor.renderControlCharacters": true,
        "editor.wordWrap": "on",
        // Formatting and linting runs EXCLUSIVELY via pre-commit (.pre-commit-config.yaml),
        // so that the editor and pre-commit do not conflict with each other. The editor therefore does not format on save
        // and does not perform any auto-fix actions.
        "editor.formatOnSave": false,
        "editor.codeActionsOnSave": {
          "source.fixAll": "never",
          "source.organizeImports": "never"
        },
        "editor.wrappingStrategy": "advanced",
        "terminal.integrated.suggest.enabled": true,
        "[javascript]": {
          "outline.showVariables": false
        },
        // - do not verify extensions signature
        // because of bug in Docker for ARM processors on Mac
        "extensions.verifySignature": false,
        "search.useIgnoreFiles": false,
        "search.exclude": {
          "**/.git": true,
          "**/export": true,
          "**/node_modules": true
        },
        // extensions settings
        "python.pythonPath": "/usr/bin/python3",
        "python.terminal.useEnvFile": true,
        /*/>
        // To tweak pylint:
        // - https://pylint.readthedocs.io/en/stable/user_guide/configuration/index.html
        // - https://pylint.readthedocs.io/en/stable/user_guide/checkers/features.html
        "pylint.args": [
            "--disable=C0111",
            "--max-line-length=120"
        ],
        //*/
        // Default formatters remain only for manual "Format Document"; auto format on save
        // is disabled above (formatting is handled by pre-commit: prettier for non-py, ruff for .py).
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.formatOnSave": false,
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        // Editor lint diagnostics are disabled — linting runs only via pre-commit
        // (ruff check + pylint). This keeps editor and pre-commit diagnostics from diverging.
        "ruff.lint.enable": false,
        "pylint.enabled": false,
        "eslint.enable": false
      }
    }
  }
}
